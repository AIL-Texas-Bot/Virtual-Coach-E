rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own data
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;

      // Daily logs — user can read/write their own
      match /dailyLogs/{date} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Weekly reports — user can read, server can write
      match /weeklyReports/{weekNumber} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Protocol versions — user can read, server can write
      match /protocolVersions/{versionId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Progress photos — user can read/write their own
      match /progressPhotos/{photoId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
